<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/rebaseBannerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Repo info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 main"
                    android:textSize="16sp"
                    android:textColor="@color/accent_green"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCommitCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 commits"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

                <!-- ✦ Copilot button — context-aware, launches with this repo loaded -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopilot"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="✦ Ask Copilot"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#6C63FF"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_help"
                    app:iconTint="@android:color/white"
                    app:iconGravity="textStart"
                    android:contentDescription="Open AI Copilot for this repository" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBranches"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🌿 Branches"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTags"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🏷️ Tags"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemotes"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🔁 Remotes"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:padding="0dp"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCollaborator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="👤 Add Collaborators"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="@color/accent"
                    android:visibility="gone" /> <!-- Hidden by default, only shown if remote is GitHub -->
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Collaborators info (only for GitHub) -->
        <LinearLayout
            android:id="@+id/llCollaboratorsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 Team Members"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_marginBottom="8dp" />

            <!-- Error state -->
            <TextView
                android:id="@+id/tvCollaboratorError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="12sp"
                android:textColor="#FF8A80"
                android:background="#22FF5252"
                android:visibility="gone" />

            <!-- Loading text -->
            <TextView
                android:id="@+id/tvCollaboratorLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Loading members..."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <!-- Per-collaborator chip rows added here dynamically -->
            <LinearLayout
                android:id="@+id/llCollaboratorRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Files section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Files"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:minHeight="60dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Create file section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create File"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="File name (e.g. hello.txt)"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="File content..."
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFileContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="4"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreateFile"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Create File"
                        android:layout_marginEnd="8dp"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportFile"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="🖼️ Import"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="10dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- Merge Conflict Alert -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConflict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="#FF5252"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#26FF5252">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 Merge Conflict Detected!"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF5252"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Some files have conflicting changes. Resolve them to continue."
                    android:textSize="13sp"
                    android:textColor="#FF8A80"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResolveConflict"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resolve Conflicts"
                    app:backgroundTint="#FF5252"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Changes to Commit -->
        <LinearLayout
            android:id="@+id/llChangesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Changes to Commit"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#1A00B0FF"> <!-- Light blue tint for changes -->

                <LinearLayout
                    android:id="@+id/llChangesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <!-- Files will be added here dynamically -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Commit section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stage &amp; Commit"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Commit message"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCommitMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCommit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stage All &amp; Commit"
                    app:backgroundTint="@color/accent_green"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Push button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPush"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬆️ Push to Remote (GitHub)"
            app:backgroundTint="@color/accent"
            app:cornerRadius="10dp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <!-- Modern High-Fidelity Graph Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModernHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Pro Visual Graph"
            app:backgroundTint="#8B5CF6"
            app:cornerRadius="10dp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <!-- History button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 View Commit History"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="10dp"
            app:strokeColor="@color/accent"
            android:textColor="@color/accent"
            android:layout_marginBottom="12dp" />

        <!-- Share via QR button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareQr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤 Share via QR Code"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/accent_green"
            app:strokeWidth="1.5dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="10dp"
            android:textColor="@color/accent_green"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
