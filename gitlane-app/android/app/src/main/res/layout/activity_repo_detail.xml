<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ── Rebase Banner (From Remote) ────────────────────────────────── -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/rebaseBannerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- ── Sticky Header (Merged) ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnHeaderBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#64748B"
                android:contentDescription="Back"
                android:layout_marginEnd="10dp"/>

            <!-- Breadcrumb path -->
            <TextView
                android:id="@+id/tvBreadcrumb"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#475569"
                android:singleLine="true"
                android:ellipsize="start"/>

            <!-- ✦ Copilot Button (Minimal version for Header) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopilot"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="✦ Copilot"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#6C63FF"
                app:cornerRadius="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="12dp"
                style="@style/Widget.Material3.Button.UnelevatedButton"/>
        </LinearLayout>

        <!-- Repo name line -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvBranch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 main"
                android:textSize="13sp"
                android:textColor="#34D399"
                android:textStyle="bold"
                android:background="#0D1F17"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvCommitCount"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="0 commits"
                android:textSize="11sp"
                android:textColor="#64748B"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Scrollable Content ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- ── Repo actions row ─────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Branches -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBranches"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Branches"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.02"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <!-- Tags -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTags"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Tags"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <!-- Remotes -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemotes"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Remotes"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <!-- Add Collaborator (GitHub only) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCollaborator"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="16dp"
                android:text="+ Add Collaborator"
                android:textSize="12sp"
                android:textColor="#38BDF8"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="#0E3A55"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

            <!-- Collaborators panel -->
            <LinearLayout
                android:id="@+id/llCollaboratorsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEAM MEMBERS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1E293B"
                    app:cardBackgroundColor="#0A0F1E">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- Error state -->
                        <TextView
                            android:id="@+id/tvCollaboratorError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:textSize="11sp"
                            android:textColor="#FF8A80"
                            android:background="#22FF5252"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp" />

                        <!-- Loading text -->
                        <TextView
                            android:id="@+id/tvCollaboratorLoading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏳ Loading members..."
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:layout_marginBottom="6dp" />

                        <!-- Per-collaborator row container -->
                        <LinearLayout
                            android:id="@+id/llCollaboratorRows"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- Legacy compatibility -->
                        <TextView
                            android:id="@+id/tvCollaboratorList"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Section: Files ───────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILES"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:textColor="#475569"
                android:layout_marginBottom="8dp"/>

            <!-- Back to parent folder (visible only when inside a subfolder) -->
            <LinearLayout
                android:id="@+id/llFolderBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="4dp"
                android:background="?attr/selectableItemBackground"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="16sp"
                    android:textColor="#64748B"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvFolderBackLabel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text=".. / back"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1E293B"
                app:cardBackgroundColor="#0A0F1E">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:minHeight="60dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Merge Conflict Alert ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConflict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#EF4444"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#1AEF4444">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚨 Merge Conflict Detected!"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Some files have conflicting changes. Resolve them to continue."
                        android:textSize="12sp"
                        android:textColor="#FDA4AF"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResolveConflict"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="Resolve Conflicts"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#EF4444"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Pending Changes ──────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/llChangesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING CHANGES"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="#475569"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#172554"
                    app:cardBackgroundColor="#0A0F1E">

                    <LinearLayout
                        android:id="@+id/llChangesList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Stage & Commit — compact trigger button ─────────────── -->
            <!-- disabled by default; RepoDetailActivity enables it when changes exist -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCommit"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="Stage All &amp; Commit"
                android:textSize="13sp"
                android:textColor="#34D399"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#14532D"
                app:strokeColor="#166534"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:enabled="false"
                android:alpha="0.40"
                style="@style/Widget.Material3.Button.OutlinedButton"/>

            <!-- stub — keeps binding.etCommitMsg valid -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCommitMsg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>


            <!-- ── Create File + Import buttons ───────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateFile"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="+ Create File"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="10dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnImportFile"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="↑ Import"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

            <!-- stubs — keep binding.etFileName/etFileContent valid -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFileName"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFileContent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>


            <!-- ── Section: Actions ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIONS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:textColor="#475569"
                android:layout_marginBottom="8dp"/>

            <!-- Sync & Push -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPush"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="44dp"
                    android:text="↑  Push to Remote"
                    android:textSize="13sp"
                    android:textColor="#38BDF8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#0E3A55"
                    app:cornerRadius="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUndoCommit"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:text="Undo"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

            <!-- Commit History + Visual Graph row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="History"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModernHistory"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="Visual Graph"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#1E293B"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

            <!-- Share via QR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareQr"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Share via QR Code"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="#1E293B"
                app:cornerRadius="8dp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
