<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0F1E"
    android:padding="24dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E2D3D"
            app:strokeWidth="1dp"
            app:strokeColor="#2A3A4D">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="#38BDF8"
                android:contentDescription="New repo"
                android:scaleType="fitCenter"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Repository"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create a local git repo"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="1dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E293B"
        android:layout_marginBottom="20dp"/>

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REPOSITORY NAME"
        android:textSize="9sp"
        android:textColor="#64748B"
        android:letterSpacing="0.12"
        android:layout_marginBottom="8dp"/>

    <!-- Input field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilRepoName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. my-awesome-project"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/accent"
        app:boxBackgroundColor="#111827"
        app:hintTextColor="#64748B"
        android:layout_marginBottom="6dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etRepoName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Rule hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Letters, numbers, hyphens and underscores only"
        android:textSize="10sp"
        android:textColor="#475569"
        android:layout_marginBottom="24dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E293B"
        android:layout_marginBottom="16dp"/>

    <!-- Action buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogCreate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Create Repository"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"
        app:backgroundTint="@color/accent"
        app:cornerRadius="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogCancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textSize="13sp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:strokeColor="#1E293B"
        android:textColor="#64748B"
        app:cornerRadius="12dp"/>

</LinearLayout>
