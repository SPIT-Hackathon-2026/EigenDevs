<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📤"
            android:textSize="56sp"
            android:layout_marginBottom="8dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share Repository"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <!-- Instructions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Have the receiving device scan this QR code.\nBoth devices must be on the same WiFi or hotspot."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Status text -->
        <TextView
            android:id="@+id/tvShareStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Preparing bundle…"
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- QR Code image -->
        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="QR Code"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- URL label -->
        <TextView
            android:id="@+id/tvShareUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="monospace"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Keep screen on hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Keep this screen open until the other device finishes downloading."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
