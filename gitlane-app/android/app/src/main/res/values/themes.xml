<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Theme.GitLane
        Base: Material3 Dark / NoActionBar
        We wire all required Material color attributes to our @color/* resources.
        Both @color/colorPrimary (AppCompat legacy) and ?attr/colorPrimary (M3)
        are satisfied this way.
    -->
    <style name="Theme.GitLane" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <!-- Error -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        <!-- Window -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <!-- Material card background -->
        <item name="colorSurfaceVariant">@color/surface</item>
    </style>

    <!-- Variant with ActionBar shown (for detail screens) -->
    <style name="Theme.GitLane.WithActionBar" parent="Theme.GitLane">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
    </style>
</resources>
