<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Network state to read local IP for QR generation -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Local HTTP server needs this on Android 9+ -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".GitLaneApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.GitLane">

        <!-- Dashboard — repo list + scan button -->
        <activity
            android:name=".ui.DashboardActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Repo detail — files, create file, commit, share -->
        <activity
            android:name=".ui.RepoDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Commit history -->
        <activity
            android:name=".ui.CommitHistoryActivity"
            android:exported="false" />

        <!-- QR Share — shows bundle QR for a repo -->
        <activity
            android:name=".ui.QRShareActivity"
            android:exported="false" />

        <!-- QR Scan — camera scan + repo import -->
        <activity
            android:name=".ui.QRScanActivity"
            android:screenOrientation="portrait"
            android:label="Scan Repository QR" />

        <activity
            android:name=".ui.SettingsActivity"
            android:label="Settings" />

        <activity
            android:name=".ui.CloneActivity"
            android:label="Clone Repository" />

        <activity
            android:name=".ui.BranchActivity"
            android:label="Branches" />

        <activity
            android:name=".ui.RemoteActivity"
            android:label="Remotes" />

        <activity
            android:name=".ui.TagActivity"
            android:label="Tags" />

        <!-- File Editor — view/edit file content -->
        <activity
            android:name=".ui.FileEditorActivity"
            android:label="Edit File"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.GitHubRepoListActivity"
            android:label="Select GitHub Repository" />

        <activity
            android:name=".ui.ConflictResolutionActivity"
            android:label="Resolve Merge Conflicts" />

        <activity
            android:name=".ui.MergeConflictActivity"
            android:label="Three-Way Merge" />

        <activity
            android:name=".ui.ModernHistoryActivity"
            android:label="Pro Git Graph" />

        <activity
            android:name=".ui.InvitationInboxActivity"
            android:label="Collaboration Inbox" />

        <activity
            android:name=".ui.GitHubOAuthActivity"
            android:exported="true"
            android:label="GitHub Login">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="gitlane" android:host="oauth" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.PublicRepoSearchActivity"
            android:label="GitHub Discovery" />

        <!-- ZXing Scanner -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="fullSensor"
            android:exported="false"
            tools:replace="screenOrientation" />

    </application>

</manifest>